{
  "manifest_version": 3,
  "name": "nicolivelog",
  "version": "0.1.0",
  "description": "ニコニコ生放送のコメントをローカルに記録するプロトタイプ（オプトイン）",
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "https://live.nicovideo.jp/*",
    "http://127.0.0.1:3456/*",
    "http://localhost:3456/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "nicolivelog",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://live.nicovideo.jp/*",
        "http://127.0.0.1:3456/*",
        "http://localhost:3456/*"
      ],
      "js": ["dist/content.js"],
      "run_at": "document_idle"
    }
  ]
}
