{
  "manifest_version": 3,
  "name": "君斗りんくの追憶のきらめき",
  "version": "0.1.6",
  "description": "ニコニコ生放送の応援コメントをこのPCに記録し、応援の可視化につなげます（開発識別子: nicolivelog）。",
  "icons": {
    "16": "images/logo/konta-yukkuri-icon-16.png",
    "32": "images/logo/konta-yukkuri-icon-32.png",
    "48": "images/logo/konta-yukkuri-icon-48.png",
    "128": "images/logo/konta-yukkuri-icon-128.png"
  },
  "permissions": [
    "storage",
    "unlimitedStorage",
    "scripting",
    "downloads",
    "alarms",
    "tabs",
    "sidePanel"
  ],
  "host_permissions": [
    "https://*.nicovideo.jp/*",
    "http://127.0.0.1:3456/*",
    "http://localhost:3456/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "君斗りんくの追憶のきらめき",
    "default_icon": {
      "16": "images/logo/konta-yukkuri-icon-16.png",
      "32": "images/logo/konta-yukkuri-icon-32.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.nicovideo.jp/*",
        "http://127.0.0.1:3456/*",
        "http://localhost:3456/*"
      ],
      "js": ["dist/page-intercept.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true,
      "match_about_blank": true,
      "match_origin_as_fallback": true
    },
    {
      "matches": [
        "https://*.nicovideo.jp/*",
        "http://127.0.0.1:3456/*",
        "http://localhost:3456/*"
      ],
      "js": ["dist/content.js"],
      "run_at": "document_idle",
      "all_frames": true,
      "match_about_blank": true,
      "match_origin_as_fallback": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "popup.html",
        "dist/popup.js",
        "images/toumeilink.png",
        "images/yukkuri-charactore-english/*/*.png"
      ],
      "matches": [
        "https://*.nicovideo.jp/*",
        "http://127.0.0.1:3456/*",
        "http://localhost:3456/*"
      ]
    }
  ]
}
